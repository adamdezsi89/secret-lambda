root = true

# ─────────────────────────────────────────────────────────────
# DEFAULT RULES FOR ALL TEXT FILES
# ─────────────────────────────────────────────────────────────
[*]
charset = utf-8
# Line endings are defined in .gitingore file and normalized by git
#end_of_line = lf

indent_style = tab
indent_size = 4

trim_trailing_whitespace = true
insert_final_newline = true

# ─────────────────────────────────────────────────────────────
# GIT CONFIG FILES
# Must be left alone — many tools generate them
# ─────────────────────────────────────────────────────────────
[.gitignore]
trim_trailing_whitespace = false

[.gitattributes]
indent_style = space
indent_size = 2

[{pre-commit,commit-msg,post-merge}]

# ─────────────────────────────────────────────────────────────
# Editorconfig itself
# ─────────────────────────────────────────────────────────────
[.editorconfig]
indent_style = space
indent_size = 2

# ─────────────────────────────────────────────────────────────
# MARKDOWN
# Keep trailing spaces because they mean manual line break
# Keep flexible indenting for lists
# ─────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2


[*.txt]
indent_style = space
indent_size = 2

# ─────────────────────────────────────────────────────────────
# SHELL SCRIPTS
# 2-space indentation (widely used)
# ─────────────────────────────────────────────────────────────
[{*.sh,mvnw}]
indent_style = space
indent_size = 2

[*.cmd]
# Line endings are defined in .gitingore file and normalized by git
#end_of_line = crlf

# ─────────────────────────────────────────────────────────────
# JSON
# Many tools enforce 2-space for JSON (npm, Prettier style)
# ─────────────────────────────────────────────────────────────
[*.json]
indent_style = space
indent_size = 2

[*.avsc]
indent_style = space
indent_size = 2

# ─────────────────────────────────────────────────────────────
# XML (Spring configs, pom.xml)
# ─────────────────────────────────────────────────────────────
[*.xml]

# ─────────────────────────────────────────────────────────────
# YAML / YML
# Strict 2-space indentation, required by K8s, Helm, GitHub Actions
# ─────────────────────────────────────────────────────────────
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# ─────────────────────────────────────────────────────────────
# PROPERTIES files (Spring Boot)
# No indentation rules guaranteed; keep minimal
# ─────────────────────────────────────────────────────────────
[*.properties]

# ─────────────────────────────────────────────────────────────
# JAVA
# Strict 4-space indentation is enforced by Spotless + Palantir Java Format
# ─────────────────────────────────────────────────────────────
[*.java]
indent_style = space
indent_size = 4
block_comment_start = /*
block_comment = *
block_comment_end = */


[*.js]
block_comment_start = /*
block_comment = *
block_comment_end = */


[*.ts]
block_comment_start = /*
block_comment = *
block_comment_end = */

[*.mustache]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false
insert_final_newline = false

[Pipfile]


[*.drawio]


[Preferences.sublime-settings]
